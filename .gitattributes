# ==============================
# 基础设置
# ==============================

# 自动处理文本文件换行符，但保持一致为 LF
* text=auto eol=lf

# ==============================
# 文本文件（强制 LF）
# ==============================

# 源代码
*.js     text eol=lf
*.jsx    text eol=lf
*.ts     text eol=lf
*.tsx    text eol=lf
*.vue    text eol=lf

# 样式
*.css    text eol=lf
*.scss   text eol=lf
*.sass   text eol=lf
*.less   text eol=lf

# 配置 / 标记文件
*.json   text eol=lf
*.yml    text eol=lf
*.yaml   text eol=lf
*.html   text eol=lf
*.xml    text eol=lf
*.md     text eol=lf
*.txt    text eol=lf
*.ini    text eol=lf
*.env    text eol=lf
*.gitignore     text eol=lf
*.gitattributes text eol=lf
*.editorconfig  text eol=lf
*.prettierrc    text eol=lf
*.npmrc         text eol=lf

# Shell / 脚本
*.sh   text eol=lf
*.bash text eol=lf
*.zsh  text eol=lf
*.bat  text eol=lf
*.cmd  text eol=lf

# ==============================
# 二进制文件（禁止 Git 改行）
# ==============================
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.ico   binary
*.svg   binary
*.webp  binary
*.avif  binary

*.zip   binary
*.gz    binary
*.tar   binary
*.7z    binary
*.pdf   binary

*.ttf   binary
*.otf   binary
*.woff  binary
*.woff2 binary
